DATABASE_URL="postgresql://user:password@localhost:5432/trx_hash"
PORT=3000

# Phase 6 登录激活
JWT_SECRET="your-jwt-secret"
PNL_SYNC_SECRET="trx-hash-pnl-sync-dev"
SUB_ADDRESS="TYourAddressFor480TRX"

# TronGrid：服务端代广播（客户端本机签名后 POST raw transaction，私钥不上传）
# 多个 Key 用英文逗号分隔，轮换使用；在 https://www.trongrid.io/ 申请
TRONGRID_API_KEYS="key1,key2,key3"
# 可选，默认 https://api.trongrid.io
# TRONGRID_BASE_URL="https://api.trongrid.io"
