# ---------- 本机直接 npm run（非 Docker）----------
DATABASE_URL="postgresql://user:password@localhost:5432/trx_hash"
PORT=3000

# ---------- Docker Compose（与 docker-compose.yml 共用；部署到云端时务必填写）----------
# 以下三项须一致：Nest 容器里的 DATABASE_URL 由 compose 用它们拼接，勿与下面本机 DATABASE_URL 混用
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=trx_hash
POSTGRES_PORT=5433
SERVER_PORT=3003

# 管理后台：首次创建管理员用（仅库中无管理员时 POST /admin/bootstrap）
ADMIN_BOOTSTRAP_SECRET="change-me-long-random-bootstrap"

# 客户端「联系我们」Telegram 二维码指向的链接（https://t.me/xxx）
TELEGRAM_INVITE_URL="https://t.me/your_group_or_username"

# Phase 6 登录激活
JWT_SECRET="your-jwt-secret"
PNL_SYNC_SECRET="trx-hash-pnl-sync-dev"
SUB_ADDRESS="TYourAddressFor480TRX"

# TronGrid：服务端代广播（客户端本机签名后 POST raw transaction，私钥不上传）
# 多个 Key 用英文逗号分隔，轮换使用；在 https://www.trongrid.io/ 申请
TRONGRID_API_KEYS="key1,key2,key3"
# 可选，默认 https://api.trongrid.io
# TRONGRID_BASE_URL="https://api.trongrid.io"
